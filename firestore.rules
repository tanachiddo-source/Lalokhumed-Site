rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'tanachiddo@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Collections ---

    match /admins/{userId} {
      // Admins can read their own record or other admins
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // No one can create/update admins from client except manually in console or by existing admin
      allow write: if false; 
    }

    match /bookings/{bookingId} {
      function isValidBooking(data) {
        return (data.get('fullName', '') is string) && (data.get('fullName', '').size() <= 200) &&
               (data.get('email', '') is string) && (data.get('email', '').size() <= 200) &&
               (data.get('phone', '') is string) && (data.get('phone', '').size() <= 50) &&
               (data.get('service', '') is string) &&
               (data.get('status', 'pending') in ['pending', 'confirmed', 'cancelled', 'suggested']);
      }

      // Public can book
      allow create: if isValidBooking(incoming()) && 
                      incoming().status == 'pending' &&
                      incoming().createdAt == request.time;
      
      // Only admins can see and update bookings
      allow read: if isAdmin();
      allow update: if isAdmin() && (
        // For updates by admins, we only enforce type safety on affected keys
        incoming().updatedAt == request.time
      );
      allow delete: if isAdmin();
    }

    match /questionnaires/{qId} {
      function isValidQuestionnaire(data) {
        return (data.get('fullName', '') is string) && (data.get('fullName', '').size() <= 200) &&
               (data.get('email', '') is string) && (data.get('email', '').size() <= 200) &&
               (data.get('signature', '') is string) && (data.get('signature', '').size() <= 200);
      }

      // Public can submit
      allow create: if isValidQuestionnaire(incoming()) && 
                      incoming().createdAt == request.time;
      
      // Clinical records are read-only for admins and immutable
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /availability/{slotId} {
      // Public can check availability
      allow read: if true;
      // Only admins manage slots
      allow write: if isAdmin();
    }

    match /notifications/{notifId} {
      // Only admins manage communication queue
      allow read, list, write: if isAdmin();
    }

    match /faq_submissions/{subId} {
      // Public can submit questions
      allow create: if (incoming().question is string) && (incoming().question.size() <= 1000) &&
                      (incoming().email is string) && (incoming().email.size() <= 200) &&
                      incoming().createdAt == request.time;
      // Only admins can see them
      allow read: if isAdmin();
    }
  }
}
